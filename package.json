{
  "name": "invoice-electron-app",
  "version": "1.1.15",
  "description": "Auto download invoices",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanhieung/accounting-utils.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --mac",
    "publish": "dotenv -- electron-builder --win --mac --publish always",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "publish:win": "dotenv -- electron-builder --win --publish always",
    "publish:mac": "dotenv -- electron-builder --mac --publish always",
    "release": "npm version patch && git push origin main --follow-tags"
  },
  "build": {
    "appId": "com.accounting.invoice-downloader",
    "productName": "Invoice Batch Downloader",
    "publish": [
      {
        "provider": "github",
        "owner": "vanhieung",
        "repo": "accounting-utils",
        "releaseType": "draft",
        "private": false
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "app_icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "app_icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tải Hóa Đơn Tự Động"
    },
    "dmg": {
      "title": "Tải Hóa Đơn Tự Động"
    }
  },
  "author": "AccountingApp",
  "dependencies": {
    "electron-updater": "^6.3.9",
    "jszip": "^3.10.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  }
}
